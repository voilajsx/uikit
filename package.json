{
  "name": "@voilajsx/uikit",
  "version": "1.0.0",
  "description": "React UI component library for admin dashboards and corporate websites",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./dist/uikit.css --minify",
    "build:all": "npm run build && npm run build:css",
    "dev": "rollup -c -w",
    "lint": "eslint src",
    "test": "jest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "clsx": "^1.2.1",
    "recharts": "^2.5.0",
    "tailwind-merge": "^1.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^22.0.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.20.0",
    "jest": "^28.1.3",
    "postcss": "^8.5.3",
    "postcss-import": "^15.1.0",
    "rollup": "^2.77.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voilajsx/uikit.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "dashboard",
    "admin",
    "design-system"
  ],
  "author": "VoilaJSX",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/voilajsx/uikit/issues"
  },
  "homepage": "https://github.com/voilajsx/uikit#readme",
  "sideEffects": false
}
