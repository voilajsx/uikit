{
  "name": "@voilajsx/uikit",
  "version": "0.1.0",
  "description": "Cross-platform React components with themes",
  "type": "module",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "shadcn",
    "cross-platform"
  ],
  "main": "dist/uikit.umd.js",
  "module": "dist/uikit.es.js",
  "exports": {
    ".": {
      "import": "./dist/uikit.es.js",
      "require": "./dist/uikit.umd.js"
    },
    "./styles": "./dist/style.css",
    "./accordion": "./dist/components/ui/accordion.js",
    "./alert": "./dist/components/ui/alert.js",
    "./avatar": "./dist/components/ui/avatar.js",
    "./badge": "./dist/components/ui/badge.js",
    "./button": "./dist/components/ui/button.js",
    "./card": "./dist/components/ui/card.js",
    "./checkbox": "./dist/components/ui/checkbox.js",
    "./dialog": "./dist/components/ui/dialog.js",
    "./dropdown-menu": "./dist/components/ui/dropdown-menu.js",
    "./form": "./dist/components/ui/form.js",
    "./input": "./dist/components/ui/input.js",
    "./label": "./dist/components/ui/label.js",
    "./popover": "./dist/components/ui/popover.js",
    "./progress": "./dist/components/ui/progress.js",
    "./radio-group": "./dist/components/ui/radio-group.js",
    "./select": "./dist/components/ui/select.js",
    "./separator": "./dist/components/ui/separator.js",
    "./sheet": "./dist/components/ui/sheet.js",
    "./skeleton": "./dist/components/ui/skeleton.js",
    "./slider": "./dist/components/ui/slider.js",
    "./switch": "./dist/components/ui/switch.js",
    "./table": "./dist/components/ui/table.js",
    "./tabs": "./dist/components/ui/tabs.js",
    "./textarea": "./dist/components/ui/textarea.js",
    "./toast": "./dist/components/ui/toast.js",
    "./toggle": "./dist/components/ui/toggle.js",
    "./tooltip": "./dist/components/ui/tooltip.js",
    "./container": "./dist/components/layouts/container.js",
    "./header": "./dist/components/layouts/header.js",
    "./footer": "./dist/components/layouts/footer.js",
    "./sidebar": "./dist/components/layouts/sidebar.js",
    "./theme-provider": "./dist/themes/theme-provider.js",
    "./utils": "./dist/lib/utils.js",
    "./platform": "./dist/lib/platform.js",
    "./adapters/hooks": "./dist/adapters/hooks.js",
    "./adapters/web": "./dist/adapters/web.js",
    "./adapters/native": "./dist/adapters/native.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate-themes": "node src/themes/theme-generator.js",
    "dev": "vite",
    "build": "npm run generate-themes && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.288.0",
    "react-hook-form": "^7.57.0",
    "tailwind-merge": "^2.6.0",
    "vite": "^6.3.5",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4"
  }
}
