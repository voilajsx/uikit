{
  "name": "@voilajsx/uikit",
  "version": "0.1.0",
  "description": "Cross-platform React components with themes",
  "type": "module",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "shadcn",
    "cross-platform",
    "typescript",
    "design-system"
